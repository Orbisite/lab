# Défaut dans le code : dépôt https://github.com/Orbisite/erlow-api (branche main).
# Surcharge optionnelle fichier par fichier :
# VITE_CONTENT_URL=https://raw.githubusercontent.com/Orbisite/erlow-api/main/content.json
# VITE_THEME_URL=https://raw.githubusercontent.com/Orbisite/erlow-api/main/theme.json
# VITE_SITE_URL=https://raw.githubusercontent.com/Orbisite/erlow-api/main/site.json
# VITE_API_IMG_BASE=https://raw.githubusercontent.com/Orbisite/erlow-api/main/img

# Ou une base commune :
# VITE_MODEL_RAW_BASE=https://raw.githubusercontent.com/Orbisite/erlow-api/main
